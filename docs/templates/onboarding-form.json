{
  "formName": "Client Onboarding Form — Invictus AI",
  "version": "1.0",
  "sections": [
    {
      "title": "Business Information",
      "fields": [
        {"name": "business_name", "label": "Business Name", "type": "text", "required": true, "placeholder": "e.g., Bright Smile Dental Clinic"},
        {"name": "owner_name", "label": "Owner / Decision Maker Name", "type": "text", "required": true},
        {"name": "phone", "label": "Primary Phone Number", "type": "phone", "required": true, "placeholder": "+91 XXXXX XXXXX"},
        {"name": "email", "label": "Business Email", "type": "email", "required": true},
        {"name": "niche", "label": "Business Type", "type": "dropdown", "required": true, "options": ["Dental Clinic", "CA / Tax Consultant", "Education / Coaching", "Law Firm / Lawyer", "Other"]},
        {"name": "niche_other", "label": "If Other, specify", "type": "text", "required": false, "showIf": {"field": "niche", "value": "Other"}},
        {"name": "address", "label": "Business Address", "type": "textarea", "required": true, "placeholder": "Full address including city and PIN code"},
        {"name": "city", "label": "City", "type": "text", "required": true},
        {"name": "years_in_business", "label": "Years in Business", "type": "dropdown", "required": true, "options": ["Less than 1 year", "1-3 years", "3-5 years", "5-10 years", "10+ years"]},
        {"name": "team_size", "label": "Team Size", "type": "dropdown", "required": true, "options": ["Just me", "2-5 people", "6-15 people", "15-50 people", "50+"]}
      ]
    },
    {
      "title": "Current Online Presence",
      "fields": [
        {"name": "current_website", "label": "Current Website URL (if any)", "type": "url", "required": false, "placeholder": "https://..."},
        {"name": "google_business_url", "label": "Google Business Profile URL", "type": "url", "required": false},
        {"name": "google_rating", "label": "Current Google Rating", "type": "dropdown", "required": false, "options": ["No reviews yet", "Below 3.0", "3.0 - 3.9", "4.0 - 4.4", "4.5 - 5.0"]},
        {"name": "instagram_handle", "label": "Instagram Handle", "type": "text", "required": false, "placeholder": "@yourbusiness"},
        {"name": "facebook_page", "label": "Facebook Page URL", "type": "url", "required": false},
        {"name": "other_social", "label": "Other Social Media / Directory Listings", "type": "textarea", "required": false, "placeholder": "LinkedIn, JustDial, Practo, etc."}
      ]
    },
    {
      "title": "About Your Business",
      "fields": [
        {"name": "business_description", "label": "Describe your business in 2-3 sentences", "type": "textarea", "required": true, "placeholder": "What do you do? What makes you different?", "maxLength": 500},
        {"name": "services", "label": "List your main services/offerings", "type": "textarea", "required": true, "placeholder": "One per line:\n- General Dentistry\n- Cosmetic Dentistry\n- Orthodontics\n- Root Canal Treatment"},
        {"name": "usp", "label": "What makes you different from competitors?", "type": "textarea", "required": false, "placeholder": "e.g., 15 years experience, latest equipment, affordable pricing, family-friendly"},
        {"name": "target_audience", "label": "Who is your ideal customer?", "type": "textarea", "required": true, "placeholder": "e.g., Families in [area], young professionals, small business owners"},
        {"name": "service_area", "label": "Areas/localities you serve", "type": "text", "required": true, "placeholder": "e.g., Koregaon Park, Camp, Kothrud, all of Pune"},
        {"name": "avg_customer_value", "label": "Average transaction value (₹)", "type": "number", "required": false, "placeholder": "e.g., 5000"},
        {"name": "monthly_customers", "label": "Approximate customers/clients per month", "type": "dropdown", "required": true, "options": ["0-10", "10-30", "30-50", "50-100", "100+"]}
      ]
    },
    {
      "title": "Branding & Design Preferences",
      "fields": [
        {"name": "logo_available", "label": "Do you have a business logo?", "type": "dropdown", "required": true, "options": ["Yes — I'll upload it", "Yes — but low quality, needs redesign", "No — please create one"]},
        {"name": "logo_upload", "label": "Upload Logo (PNG or SVG preferred)", "type": "file", "required": false, "accept": ".png,.svg,.jpg,.jpeg,.pdf"},
        {"name": "brand_colors", "label": "Preferred Colors", "type": "text", "required": false, "placeholder": "e.g., Blue and white, or #1A73E8, or 'I'll leave it to you'"},
        {"name": "design_style", "label": "Design Style Preference", "type": "dropdown", "required": true, "options": ["Modern & Clean", "Traditional & Professional", "Bold & Vibrant", "Elegant & Premium", "Friendly & Approachable", "No preference — surprise me"]},
        {"name": "reference_websites", "label": "Websites you like (for reference)", "type": "textarea", "required": false, "placeholder": "Share 2-3 URLs of websites whose style you like"},
        {"name": "photos_available", "label": "Do you have professional photos of your business?", "type": "dropdown", "required": true, "options": ["Yes — high quality photos ready", "Some photos, not professional", "No photos available", "I'll get them taken"]},
        {"name": "photo_upload", "label": "Upload Business Photos (office, team, products)", "type": "file", "required": false, "accept": ".png,.jpg,.jpeg", "multiple": true, "maxFiles": 20}
      ]
    },
    {
      "title": "Goals & Expectations",
      "fields": [
        {"name": "goals", "label": "What do you want to achieve? (select all that apply)", "type": "checkbox", "required": true, "options": [
          "Get more leads/enquiries",
          "Professional website",
          "Rank higher on Google",
          "Automate follow-ups & reminders",
          "Get more Google reviews",
          "Social media presence",
          "Online booking/appointment system",
          "Email/SMS marketing",
          "Beat local competitors",
          "Other"
        ]},
        {"name": "goals_other", "label": "Other goals", "type": "text", "required": false, "showIf": {"field": "goals", "includes": "Other"}},
        {"name": "biggest_challenge", "label": "What's your biggest business challenge right now?", "type": "textarea", "required": true, "maxLength": 300},
        {"name": "timeline", "label": "When do you want to go live?", "type": "dropdown", "required": true, "options": ["ASAP (within 1 week)", "Within 2 weeks", "Within 1 month", "No rush — take your time"]},
        {"name": "domain_preference", "label": "Domain Name Preference", "type": "text", "required": false, "placeholder": "e.g., www.mybusiness.com (we'll check availability)"},
        {"name": "has_domain", "label": "Do you already own a domain?", "type": "dropdown", "required": true, "options": ["Yes", "No — I need one", "Not sure"]}
      ]
    },
    {
      "title": "Competitor Information",
      "fields": [
        {"name": "competitor_1", "label": "Competitor 1 — Name & Website", "type": "text", "required": false, "placeholder": "e.g., Smile Dental — www.smilidental.com"},
        {"name": "competitor_2", "label": "Competitor 2 — Name & Website", "type": "text", "required": false},
        {"name": "competitor_3", "label": "Competitor 3 — Name & Website", "type": "text", "required": false},
        {"name": "competitor_notes", "label": "What do they do better than you online?", "type": "textarea", "required": false}
      ]
    },
    {
      "title": "Additional Information",
      "fields": [
        {"name": "special_requirements", "label": "Any special requirements or features?", "type": "textarea", "required": false, "placeholder": "e.g., multi-language support, blog, e-commerce, specific integrations"},
        {"name": "existing_tools", "label": "Tools you currently use", "type": "checkbox", "required": false, "options": [
          "Google Workspace",
          "WhatsApp Business",
          "Practo / JustDial / Sulekha",
          "Tally / QuickBooks",
          "Social media scheduling tool",
          "Email marketing tool",
          "None of these"
        ]},
        {"name": "how_heard", "label": "How did you hear about Invictus AI?", "type": "dropdown", "required": false, "options": ["Google Search", "Social Media", "Referral", "Cold Email", "WhatsApp", "LinkedIn", "Other"]},
        {"name": "additional_notes", "label": "Anything else you'd like us to know?", "type": "textarea", "required": false}
      ]
    },
    {
      "title": "Agreement & Consent",
      "fields": [
        {"name": "consent_terms", "label": "I agree to the Terms of Service and Privacy Policy", "type": "checkbox_single", "required": true, "link": "https://www.invictus-ai.in/terms"},
        {"name": "consent_communication", "label": "I agree to receive project updates via WhatsApp and email", "type": "checkbox_single", "required": true},
        {"name": "consent_showcase", "label": "I allow Invictus AI to use my project as a portfolio piece / case study (optional)", "type": "checkbox_single", "required": false}
      ]
    }
  ],
  "ghl_mapping": {
    "contact_fields": {
      "firstName": "{{owner_name.split(' ')[0]}}",
      "lastName": "{{owner_name.split(' ').slice(1).join(' ')}}",
      "email": "{{email}}",
      "phone": "{{phone}}",
      "companyName": "{{business_name}}",
      "address1": "{{address}}",
      "city": "{{city}}",
      "tags": ["onboarded", "{{niche}}", "{{city}}"]
    },
    "custom_fields": {
      "niche": "{{niche}}",
      "current_website": "{{current_website}}",
      "google_rating": "{{google_rating}}",
      "design_style": "{{design_style}}",
      "timeline": "{{timeline}}",
      "goals": "{{goals}}"
    },
    "pipeline_action": {
      "pipelineId": "R6G5m2bF6vxtoho9ZeQH",
      "stageId": "4d4c4dbd-5c40-42c9-8bbf-24e8a0795bd3",
      "stageName": "Intake Form"
    }
  }
}
